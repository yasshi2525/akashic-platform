PUBLIC_PORT=3031
ADMIN_PORT=3033
BASE_PATH=/playlog
STORAGE_ADMIN_TOKEN=
CLIENT_ORIGIN=http://localhost:3000
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_NO_TLS=false
INFLIGHT_REQUEST_LIMIT=1000
# 接続リセット後の再接続時間を含むため、デフォルト (250ms) より長く設定する
REQUEST_TIMEOUT=2000
# クラスタートポロジー変化の検知間隔 (秒)
PERIODIC_CHECK_INTERVAL=30
# 接続リセット後の再接続バックオフ設定
# 再接続間隔 = rand(0 ... CONNECTION_BACKOFF_FACTOR * (CONNECTION_BACKOFF_BASE ^ N)) ms
# N は失敗回数。CONNECTION_BACKOFF_RETRIES 回を超えると一定間隔になる。
CONNECTION_BACKOFF_RETRIES=8
CONNECTION_BACKOFF_FACTOR=500
CONNECTION_BACKOFF_BASE=2
